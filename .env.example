# Database (Supabase PostgreSQL)
# --- REQUIRED: TWO connection strings for Supabase + Prisma ---
#
# DATABASE_URL: connection pooler URL (PgBouncer, port 6543).
#   Used by the running app for all queries.
#   Find it in: Supabase Dashboard → Project Settings → Database → Connection string → "Transaction" mode
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# DIRECT_URL: direct TCP connection (port 5432, no pooler).
#   Used ONLY by Prisma Migrate — never touches PgBouncer.
#   Find it in: Supabase Dashboard → Project Settings → Database → Connection string → "Session" mode
#   (or the "Direct connection" string under URI)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET="your-256-bit-secret-here"

# JWT expiry (optional, defaults to 7d)
JWT_EXPIRES_IN="7d"

# Port (Render injects PORT automatically)
PORT=3000

# CORS — comma-separated list of allowed origins
# Production: https://myflow.chat,https://www.myflow.chat
# Development: http://localhost:5173
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3001"

# Groq API key — free tier, no credit card
# Sign up at console.groq.com → API Keys → Create
GROK_API="gsk_your_groq_api_key_here"

# Node environment
NODE_ENV="development"

# Paddle Billing (Week 3)
# Webhook secret key — from Paddle Dashboard → Notifications → Webhook endpoint
PADDLE_WEBHOOK_SECRET="your-paddle-webhook-secret"

# Paddle price IDs (from Paddle Dashboard → Catalog → Prices) — PRIMARY matching key
PADDLE_STARTER_PRICE_ID="pri_xxxxxxxx"
PADDLE_PRO_PRICE_ID="pri_xxxxxxxx"

# Paddle product IDs (from Paddle Dashboard → Catalog → Products) — fallback matching key
PADDLE_STARTER_PRODUCT_ID="pro_xxxxxxxx"
PADDLE_PRO_PRODUCT_ID="pro_xxxxxxxx"
