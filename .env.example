# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET="your-256-bit-secret-here"

# JWT expiry (optional, defaults to 7d)
JWT_EXPIRES_IN="7d"

# Port (Render injects PORT automatically)
PORT=3000

# CORS — comma-separated list of allowed origins
# Example: https://app.chatflow.io,https://chat.chatflow.io
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3001"

# Groq API key — free tier, no credit card
# Sign up at console.groq.com → API Keys → Create
GROK_API="gsk_your_groq_api_key_here"

# Node environment
NODE_ENV="development"

# Paddle Billing (Week 3)
# Webhook secret key — from Paddle Dashboard → Notifications → Webhook endpoint
PADDLE_WEBHOOK_SECRET="your-paddle-webhook-secret"

# Paddle product IDs (from Paddle Dashboard → Catalog → Products)
PADDLE_STARTER_PRODUCT_ID="pro_xxxxxxxx"
PADDLE_PRO_PRODUCT_ID="pro_xxxxxxxx"
