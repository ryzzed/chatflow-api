// ChatFlow Prisma schema
// Database: Supabase PostgreSQL (free tier)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                          String    @id @default(cuid())
  email                       String    @unique
  password                    String
  name                        String?
  plan                        Plan      @default(FREE)
  paddleCustomerId            String?
  paddleSubscriptionId        String?
  // "active" | "past_due" | "paused" | "cancelled" | "trialing"
  paddleSubscriptionStatus    String?
  paddleNextBillDate          DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  bots            Bot[]
  webhookEvents   PaddleWebhookEvent[]

  @@map("users")
}

// Idempotency table — one row per processed Paddle event ID
model PaddleWebhookEvent {
  id          String   @id              // Paddle event_id (e.g. "evt_01h...")
  eventType   String
  processedAt DateTime @default(now())
  userId      String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("paddle_webhook_events")
}

model Bot {
  id             String   @id @default(cuid())
  name           String
  welcomeMessage String   @default("Hi! How can I help you?")
  systemPrompt   String   @default("You are a helpful assistant.")
  allowedTopics  String   @default("")
  accentColor    String   @default("#6366f1")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@map("bots")
}

model Conversation {
  id        String   @id @default(cuid())
  sessionId String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  botId    String
  bot      Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("conversations")
}

model Message {
  id        String      @id @default(cuid())
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

enum Plan {
  FREE
  STARTER
  PRO
}

enum MessageRole {
  user
  assistant
  system
}
